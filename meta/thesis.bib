@article{burlet-vienneyNeedComprehensiveApproach2014,
  title = {The {{Need}} for a {{Comprehensive Approach}} to {{Managing Confined Space Entry}}: {{Summary}} of the {{Literature}} and {{Recommendations}} for {{Next Steps}}},
  shorttitle = {The {{Need}} for a {{Comprehensive Approach}} to {{Managing Confined Space Entry}}},
  author = {Burlet-Vienney, Damien and Chinniah, Yuvin and Bahloul, Ali},
  date = {2014-08-03},
  journaltitle = {Journal of Occupational and Environmental Hygiene},
  volume = {11},
  number = {8},
  eprint = {24467798},
