  booktitle = {2024 36th {{Conference}} of {{Open Innovations Association}} ({{FRUCT}})},
  author = {Amin, Yasir Mahmood and Meftin, Noor Kadhim and Nas, Yousif Fuad and Al-Dulaimi, Mohammed K. H. and Hamid, Alaa Saad and Noga, Henryk and Khlaponina, Anastasiia},
